{
  "name": "ani-web",
  "version": "1.2.5",
  "description": "A web application for watching anime.",
  "main": "orchestrator.js",
  "bin": {
    "ani-web": "orchestrator.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "setup": "npm install --prefix client && npm install --prefix server",
    "build": "npm run build --prefix client && npm run build --prefix server",
    "start": "node orchestrator.js prod",
    "dev": "node orchestrator.js dev",
    "client": "npm start --prefix client",
    "server": "npm start --prefix server",
    "preview": "node orchestrator.js prod",
    "lighthouse": "npm run lighthouse --prefix client",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "npm run lint --prefix client && npm run lint --prefix server",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build",
    "update-version": "node update-version.js"
  },
  "files": [
    "orchestrator.js",
    "client/dist",
    "server/dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "anime",
    "react",
    "express",
    "typescript",
    "streaming",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.15.1",
    "axios-retry": "^4.5.0",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "prettier": "^3.8.3"
  }
}
